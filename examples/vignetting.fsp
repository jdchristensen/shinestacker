{"project": [{"type_name": "Job", "params": {"name": "img-vignetted-focus-stack", "working_path": "./input", "input_path": "img-vignetted"}, "sub_actions": [{"type_name": "CombinedActions", "params": {"name": "img-vignetted-preprocess"}, "sub_actions": [{"type_name": "AlignFrames", "params": {"name": "align", "detector": "AKAZE", "descriptor": "AKAZE", "match_method": "NORM_HAMMING", "flann_idx_kdtree": 2, "flann_trees": 5, "flann_checks": 50, "threshold": 0.75, "transform": "ALIGN_RIGID", "align_method": "RANSAC", "rans_threshold": 3.0, "min_good_matches": 50, "align_confidence": 99.9, "refine_iters": 100, "max_iters": 2000, "abort_abnormal": true, "subsample": 1, "fast_subsampling": false, "border_mode": "BORDER_REPLICATE_BLUR", "border_value": [0, 0, 0, 0], "border_blur": 50.0, "plot_summary": false, "plot_matches": false}}, {"type_name": "BalanceFrames", "params": {"name": "balance"}}, {"type_name": "Vignetting", "params": {"name": "vignetting", "r_steps": 100, "black_threshold": 1, "subsample": 0, "fast_subsampling": false, "max_correction": 0.9, "plot_correction": false, "plot_summary": false}}]}, {"type_name": "FocusStack", "params": {"name": "img-vignetted-focus-stack-pyramid", "stacker": "Pyramid"}}]}], "version": 1}